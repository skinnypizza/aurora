# ──────────────────────────────────────────────
#  Scrumban App — Environment Configuration
# ──────────────────────────────────────────────

# Server Port (default: 3737)
PORT=3737

# ── MODE: Local vs Cloud ──
# Set to 'true' to force local mode (no MongoDB, no auth)
# Defaults to LOCAL if MONGO_URI is empty/not set
USE_LOCAL_MODE=true

# ── JWT Secret (required for Cloud Mode) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JWT_SECRET=

# ── CORS Origin (Cloud Mode) ──
# Set to your frontend domain in production
# CORS_ORIGIN=https://tudominio.com

# ── MongoDB Atlas (Cloud Mode) ──
# Leave empty or commented to use LOCAL mode with JSON files
# Uncomment and fill in to use cloud mode with authentication
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB=scrumban

# ── Stripe (Subscription Payments) ──
# Required only if you want subscription payments in cloud mode
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── App URL (for Stripe redirects) ──
# BASE_URL=http://localhost:3737

# ── OpenCollective (Donations) ──
# OPENCOLLECTIVE_SLUG=scrumban-app
